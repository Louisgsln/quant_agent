# ============================================================================
# Anthropic API
# ============================================================================
# Get your key from https://console.anthropic.com/settings/keys
# Format: sk-ant-...
ANTHROPIC_API_KEY=

# Model to use for the agent. Defaults to Claude Opus if unset.
# Options: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-opus-4-7

# ============================================================================
# Agent runtime config
# ============================================================================
# Maximum number of ReAct iterations before the agent gives up.
AGENT_MAX_ITERATIONS=15

# Maximum total tokens budget per agent run (input + output across all turns).
AGENT_MAX_TOKENS_BUDGET=100000

# ============================================================================
# Logging
# ============================================================================
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log format: 'json' for production / structured logs, 'console' for dev.
LOG_FORMAT=console

# ============================================================================
# Data
# ============================================================================
# Override the default cache directory (~/.quant_agent_cache).
# QUANT_AGENT_CACHE_DIR=/path/to/cache